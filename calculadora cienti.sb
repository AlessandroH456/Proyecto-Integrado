GraphicsWindow.PenColor = "white"
GraphicsWindow.DrawRectangle(9,155,313,340)
GraphicsWindow.DrawRectangle(5,8,321,492)
GraphicsWindow.CanResize = "No"

caja = Controls.AddTextBox(17,50)
